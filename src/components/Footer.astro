---
import { trinl } from '~/i18n.ts';
---

<style>
	footer {
		border-top: 2px solid var(--border);
		padding: 2em 1em 6em 1em;
		bottom: 0;
		background: var(--bg);
		text-align: center;
	}
</style>

<footer>
	{trinl({
		'en': 'Who would read this? Whoever you are, you are very observant. Have fun!',
		'ru': 'Кто бы это читал? Кем бы вы ни были, вы очень наблюдательны. Веселитесь!',
		'be': 'Хто б гэта чытаў? Кім бы вы ні былі, вы вельмі назіральныя. Весяліцеся!',
		'la': 'Quis hoc legeret? Quicumque es, valde observans es. Fruere!',
	})}
</footer>
