---
const { status } = Astro.props;
---

<style>
	.status {
		display: block;
		font-size: 0.8em;
		width: fit-content;
    margin-top: 0 !important;
	  margin-bottom: 0.5em !important;

		padding: 0.2em 0.3em !important;
		border-radius: 0.7em;

		color: var(--text) !important;
		background: var(--accent);
	}
</style>

{status && <p class="status">{status}</p>}
